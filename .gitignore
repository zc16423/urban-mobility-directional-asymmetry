# Large or unavailable daily mobility/prediction folders. Do not generate by default.
basic_data/real_day/
basic_data/choice_iom_day/
basic_data/iom_day/

# Optional sample data allowlist
# Small public examples may be committed intentionally under these folders.
!sample_data/
!sample_data/**
!examples/
!examples/**
!examples/**/*.csv
!sample_data/**/*.csv

# Always keep repository documentation, source code, and manuscript source visible.
!README.md
!rename_map.md
!workflow.md
!.gitignore
!docs/
!docs/**
!*.py
!*.md
!*.tex
!*.bib
!*.bst
!*.sty
!*.cls
!*.txt
!manuscript/**
