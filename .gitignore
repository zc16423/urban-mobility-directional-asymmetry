*.fls
*.out
*.synctex.gz

# External data archive contents
# The GitHub repository is code/docs/manuscript-first. Full data should be
# hosted in Zenodo, OSF, institutional storage, or another external archive.
basic_data/**/*.csv
basic_data/*.csv
city_distance_matrices/**/*.csv
city_distance_matrices/*.csv
city_population_poi/**/*.csv
city_population_poi/*.csv
