# Generated figures and outputs
# Keep code and documentation in figure folders, but avoid committing generated
# image/PDF outputs unless a specific final manuscript asset is intentionally allowed.
figure_1/**/*.png
figure_1/**/*.jpg
figure_1/**/*.jpeg
figure_1/**/*.tif
figure_1/**/*.tiff
figure_1/**/*.pdf
figure_1/**/*.svg
